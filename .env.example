# ------------------------------------------
# General
# ------------------------------------------
NODE_ENV=development
PORT=4001
CORS_ORIGIN=*

# ------------------------------------------
# Database Configuration
# ------------------------------------------
DATABASE_URL=postgres://postgres:pasword123@localhost:5432/inbuild_whatsapp
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE=60000
DB_POOL_IDLE=20000
DB_POOL_EVICT=1000
DB_RETRY_MAX=5
DB_RETRY_BACKOFF_BASE=1000
DB_RETRY_BACKOFF_EXPONENT=1.5
DB_RETRY_TIMEOUT=5000
DB_STATEMENT_TIMEOUT=5000
DB_IDLE_TRANSACTION_TIMEOUT=10000
DB_CONNECT_TIMEOUT=5000
DB_SSL=false
DB_BENCHMARK=true


# ------------------------------------------
# Logging
# ------------------------------------------
LOG_DIR=./logs
LOG_MAX_STRING_LENGTH=1024
LOG_LEVEL=info